---
import "../styles/global.css";
import LanguageSwitch from "../components/LanguageSwitch.astro";

interface Props {
  title: string;
  description: string;
  lang?: "en" | "th";
  counterpartPath?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  lang = "en",
  counterpartPath,
  noindex = false,
} = Astro.props;

const homePath = lang === "th" ? "/th/" : "/en/";
const guidePath = lang === "th" ? "/th/guide/" : "/en/guide/";
const lessonsPath = lang === "th" ? "/th/lessons/" : "/en/lessons/";
const registryPath = lang === "th" ? "/th/registry/" : "/en/registry/";
const mapPath = lang === "th" ? "/th/map/" : "/en/map/";
const fullTitle = title === "Electrical Atlas" ? title : `${title} • Electrical Atlas`;
---

<!doctype html>
<html lang={lang} data-lesson-mode="guided">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex ? <meta name="robots" content="noindex,follow" /> : null}
    <meta name="theme-color" content="#f7f3e8" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{fullTitle}</title>
    <script is:inline>
      try {
        const savedMode = localStorage.getItem("ea.lessonMode") || "guided";
        document.documentElement.dataset.lessonMode = savedMode;
      } catch {
        document.documentElement.dataset.lessonMode = "guided";
      }
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">{lang === "th" ? "ข้ามไปยังเนื้อหา" : "Skip to content"}</a>
    <header class="site-header">
      <a class="brand" href={homePath} aria-label={lang === "th" ? "หน้าแรก Electrical Atlas" : "Electrical Atlas home"}>
        <span class="brand-mark" aria-hidden="true">⚡</span>
        <span>
          <strong>Electrical Atlas</strong>
          <small>{lang === "th" ? "แผนที่ความรู้ไฟฟ้า" : "visual knowledge map"}</small>
        </span>
      </a>

      <nav class="site-nav" aria-label={lang === "th" ? "เมนูหลัก" : "Primary"}>
        <a href={guidePath}>{lang === "th" ? "วิธีใช้เว็บ" : "Guide"}</a>
        <a href={registryPath}>{lang === "th" ? "สถานะ" : "Status"}</a>
        <a href={lessonsPath}>{lang === "th" ? "บทเรียน" : "Lessons"}</a>
        <a href={mapPath}>{lang === "th" ? "แผนที่วิชา" : "Subject map"}</a>
      </nav>

      <LanguageSwitch locale={lang} counterpartPath={counterpartPath} />
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        {lang === "th"
          ? "ต้นแบบ v0.1 — แต่ละบทแสดงระดับการทบทวนของตน ภาพอธิบายและหมายเหตุความปลอดภัยยังอยู่ระหว่างการตรวจทีละบท"
          : "Prototype v0.1 — each lesson shows its review maturity; conceptual visuals and safety notes remain under ongoing review"}
      </p>
      <p>
        {lang === "th"
          ? "บริบทประเทศไทย: แต่ละบทแสดงสถานะแหล่งอ้างอิง ข้อความด้านมาตรฐานและความปลอดภัยต้องผ่านการยืนยันจาก มอก., วสท., กฟน., กฟภ., กกพ., กสทช. หรือ มว. ก่อนนำไปใช้"
          : "Thailand context: source status is shown per lesson; standards and safety claims require TISI/TIS, EIT, MEA, PEA, ERC, NBTC, or NIMT verification before use"}
      </p>
    </footer>
  </body>
</html>
