---
import {
  getLessonById,
  getLessonStatusLabel,
  getSafetyLevelLabel,
  getSourceStatusLabel,
} from "../lib/lessonRegistry";

interface Props {
  locale?: "en" | "th";
  eyebrow: string;
  title: string;
  subtitle: string;
  lessonId: string;
}

const { locale = "en", eyebrow, title, subtitle, lessonId } = Astro.props;
const lesson = getLessonById(lessonId);
const metadataLabel = locale === "th" ? "ข้อมูลบทเรียน" : "Lesson metadata";
const metaItems = lesson
  ? [
      lesson.lessonId,
      `${locale === "th" ? "สถานะ" : "status"}: ${getLessonStatusLabel(lesson.status, locale)}`,
      `${locale === "th" ? "ความปลอดภัย" : "safety"}: ${getSafetyLevelLabel(lesson.safetyLevel, locale)}`,
      `${locale === "th" ? "แหล่งอ้างอิง" : "sources"}: ${getSourceStatusLabel(lesson.sourceStatus, locale)}`,
      lesson.requiresThailandContext
        ? locale === "th"
          ? "บริบทไทย: ต้องตรวจแหล่งอ้างอิงเมื่อกล่าวถึงมาตรฐาน/การใช้งานจริง"
          : "Thailand context: verify local references before standards/practice claims"
        : "",
    ].filter(Boolean)
  : [
      lessonId,
      `${locale === "th" ? "สถานะ" : "status"}: ${locale === "th" ? "ต้นแบบ" : "prototype"}`,
      `${locale === "th" ? "ระดับ" : "depth"}: ${locale === "th" ? "เริ่มต้น → เทคนิค" : "beginner → technical"}`,
    ];
---

<article class="lesson-shell">
  <header class="lesson-hero">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>
      <div class="lesson-meta" aria-label={metadataLabel}>
        {metaItems.map((item) => <span>{item}</span>)}
      </div>
    </div>
  </header>

  <slot />
</article>

