        label: "เปิดแผนที่",
      },
    ],
    currentPartsTitle: "ตอนนี้เว็บมีอะไรแล้ว",
    currentParts: [
      {
        name: "หน้าแรก",
        body: "หน้าต้อนรับที่บอกทิศทางของโปรเจกต์และทางเข้าหลัก",
      },
      {
        name: "บทเรียนแรก",
        body: "บทเรียนต้นแบบที่เปิดอ่านได้ เรื่องประจุ สนามไฟฟ้า แรงดัน กระแส และแบตเตอรี่ที่ทำให้หลอดไฟติด",
      },
