---

<section class="guide-hero">
  <p class="eyebrow">{copy.eyebrow}</p>
  <h1>{copy.title}</h1>
  <p class="hero-subtitle">{copy.subtitle}</p>
</section>

<section class="guide-section" aria-labelledby="quick-start-title">
  <div class="section-heading">
    <p class="eyebrow">{copy.startEyebrow}</p>
    <h2 id="quick-start-title">{copy.quickStartTitle}</h2>
    <p>{copy.quickStartIntro}</p>
  </div>

  <div class="guide-step-grid">
    {copy.quickStart.map((step) => (
      <article class="guide-step-card">
        <h3>{step.title}</h3>
        <p>{step.body}</p>
        <a class="text-link" href={step.href}>{step.label}</a>
      </article>
    ))}
  </div>
</section>

<section class="guide-section" aria-labelledby="current-parts-title">
  <div class="section-heading">
    <p class="eyebrow">{copy.partsEyebrow}</p>
    <h2 id="current-parts-title">{copy.currentPartsTitle}</h2>
  </div>

  <div class="guide-list-grid">
    {copy.currentParts.map((part) => (
      <article class="guide-list-card">
        <h3>{part.name}</h3>
        <p>{part.body}</p>
      </article>
    ))}
  </div>
</section>

<section class="guide-two-column">
  <article class="guide-panel">
    <p class="eyebrow">{copy.lessonEyebrow}</p>
    <h2>{copy.lessonTitle}</h2>
    <ol>
      {copy.lessonSteps.map((step) => <li>{step}</li>)}
    </ol>
  </article>

  <article class="guide-panel">
    <p class="eyebrow">{copy.mapEyebrow}</p>
    <h2>{copy.mapTitle}</h2>
    <ol>
      {copy.mapSteps.map((step) => <li>{step}</li>)}
    </ol>
  </article>
</section>

<section class="guide-status-card" aria-labelledby="status-rule-title">
  <p class="eyebrow">{copy.statusEyebrow}</p>
  <h2 id="status-rule-title">{copy.statusTitle}</h2>
  <p>{copy.statusBody}</p>
</section>

<section class="guide-section" aria-labelledby="choose-path-title">
  <div class="section-heading">
    <p class="eyebrow">{copy.pathsEyebrow}</p>
    <h2 id="choose-path-title">{copy.pathsTitle}</h2>
  </div>

  <div class="guide-path-list">
    {copy.paths.map((path) => (
      <article>
        <h3>{path.label}</h3>
        <p>{path.route}</p>
      </article>
    ))}
  </div>
</section>

<section class="guide-status-card guide-next-card">
  <p class="eyebrow">{copy.nextEyebrow}</p>
  <h2>{copy.nextTitle}</h2>
  <p>{copy.nextBody}</p>
</section>
