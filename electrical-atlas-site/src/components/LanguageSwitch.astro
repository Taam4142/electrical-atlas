---
import { locales, type Locale } from "../lib/navigation";

interface Props {
  locale: Locale;
  counterpartPath?: string;
}

const { locale, counterpartPath } = Astro.props;
const targetLocale = locale === "en" ? "th" : "en";
const fallbackPath = targetLocale === "th" ? "/th/" : "/en/";
const currentLabel = locales[locale].nativeLabel;
const targetLabel = locales[targetLocale].nativeLabel;
const ariaLabel =
  locale === "th"
    ? `ภาษาปัจจุบัน: ${currentLabel}; เปลี่ยนเป็น ${targetLabel}`
    : `Current language: ${currentLabel}; switch to ${targetLabel}`;
---

<a class="language-switch" href={counterpartPath ?? fallbackPath} lang={locale} aria-label={ariaLabel}>
  <span aria-hidden="true">🌐</span>
  {currentLabel}
</a>
