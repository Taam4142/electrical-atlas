---
import {
  getSafetyLevelLabel,
  getSourceStatusLabel,
  getLessonStatusLabel,
  lessonRegistry,
  type Locale,
  type NavGroup,
} from "../lib/lessonRegistry";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;

const groupLabels: Record<NavGroup, Record<Locale, string>> = {
  foundation: {
    en: "foundation",
    th: "พื้นฐาน",
  },
  component: {
    en: "component",
    th: "ชิ้นส่วน",
  },
  circuit: {
    en: "circuit",
    th: "วงจร",
  },
  power: {
    en: "power",
    th: "กำลัง/พลังงาน",
  },
  safety: {
    en: "safety",
    th: "ความปลอดภัย",
  },
  application: {
    en: "application",
    th: "การใช้งาน",
  },
};

const copy = {
  en: {
    eyebrow: "lesson registry v0.1",
    title: "Lesson status board",
    subtitle:
      "This page shows which lessons are public, planned, source-sensitive, or waiting for Thailand-context review. It is a project control surface, not a finished curriculum page.",
    summaryTitle: "Snapshot",
    total: "total registered lessons",
    publicLessons: "public lessons",
    plannedLessons: "planned lessons",
    sourceNeeded: "need source review",
    thailandContext: "need Thailand context",
    registryTitle: "Registered lessons",
    registryNote:
      "A lesson may be listed here before it has a public page. That is intentional: the registry tracks the roadmap separately from publication readiness.",
    status: "status",
    group: "group",
    safety: "safety",
    sources: "sources",
    page: "page",
    publicPage: "open lesson",
    notPublic: "not public yet",
    thailandYes: "Thailand context required",
    thailandNo: "general context",
    id: "ID",
    primaryTopic: "primary topic",
    coveredTopics: "covered topics",
  },
  th: {
    eyebrow: "lesson registry v0.1",
    title: "กระดานสถานะบทเรียน",
    subtitle:
      "หน้านี้แสดงว่าบทเรียนไหนเผยแพร่แล้ว วางแผนไว้ ต้องตรวจแหล่งอ้างอิง หรือต้องมีบริบทมาตรฐาน/การใช้งานในประเทศไทย เป็นหน้าคุมโปรเจกต์ ไม่ใช่บทเรียนเต็ม",
    summaryTitle: "ภาพรวมตอนนี้",
    total: "บทเรียนในทะเบียนทั้งหมด",
    publicLessons: "บทเรียนที่เปิดอ่านได้",
    plannedLessons: "บทเรียนที่วางแผนไว้",
    sourceNeeded: "ต้องตรวจแหล่งอ้างอิง",
    thailandContext: "ต้องตรวจบริบทไทย",
    registryTitle: "รายการบทเรียนในทะเบียน",
    registryNote:
      "บทเรียนอาจอยู่ในหน้านี้ก่อนมีหน้า public ได้โดยตั้งใจ เพราะ registry แยก roadmap ออกจากความพร้อมเผยแพร่",
    status: "สถานะ",
    group: "กลุ่ม",
    safety: "ความปลอดภัย",
    sources: "แหล่งอ้างอิง",
    page: "หน้าเว็บ",
    publicPage: "เปิดบทเรียน",
    notPublic: "ยังไม่เปิด public",
    thailandYes: "ต้องมีบริบทไทย",
    thailandNo: "บริบททั่วไป",
    id: "ID",
    primaryTopic: "หัวข้อหลัก",
    coveredTopics: "หัวข้อที่ครอบคลุม",
  },
}[locale];

const lessons = [...lessonRegistry].sort((a, b) => a.order - b.order);
const totalLessons = lessons.length;
const publicLessons = lessons.filter((lesson) => lesson.hasPage[locale]).length;
const plannedLessons = lessons.filter((lesson) => lesson.status === "planned").length;
const sourceNeededLessons = lessons.filter((lesson) => lesson.sourceStatus === "needed").length;
const thailandContextLessons = lessons.filter((lesson) => lesson.requiresThailandContext).length;
const summaries = [
  { value: totalLessons, label: copy.total },
  { value: publicLessons, label: copy.publicLessons },
  { value: plannedLessons, label: copy.plannedLessons },
  { value: sourceNeededLessons, label: copy.sourceNeeded },
  { value: thailandContextLessons, label: copy.thailandContext },
];
---

<section class="registry-hero">
  <p class="eyebrow">{copy.eyebrow}</p>
  <h1>{copy.title}</h1>
  <p class="hero-subtitle">{copy.subtitle}</p>
</section>

<section class="registry-section" aria-labelledby="registry-summary-title">
  <div class="section-heading">
    <p class="eyebrow">project control</p>
    <h2 id="registry-summary-title">{copy.summaryTitle}</h2>
  </div>

  <div class="registry-summary-grid">
    {summaries.map((item) => (
      <article class="registry-summary-card">
        <strong>{item.value}</strong>
        <span>{item.label}</span>
      </article>
    ))}
  </div>
</section>

<section class="registry-section" aria-labelledby="registry-list-title">
  <div class="section-heading">
    <p class="eyebrow">roadmap ≠ publication</p>
    <h2 id="registry-list-title">{copy.registryTitle}</h2>
    <p>{copy.registryNote}</p>
  </div>

  <div class="registry-card-grid">
    {lessons.map((lesson) => {
      const hasPublicPage = lesson.hasPage[locale];
      return (
        <article class="registry-card">
          <div class="registry-card-topline">
            <code>{String(lesson.order).padStart(2, "0")}</code>
            <span class={`registry-badge registry-badge-${lesson.status}`}>
              {getLessonStatusLabel(lesson.status, locale)}
            </span>
          </div>

          <h3>{lesson.titles[locale]}</h3>
          <p>{lesson.summaries[locale]}</p>

          <dl class="registry-detail-list">
            <div>
              <dt>{copy.group}</dt>
              <dd>{groupLabels[lesson.navGroup][locale]}</dd>
            </div>
            <div>
              <dt>{copy.safety}</dt>
              <dd>{getSafetyLevelLabel(lesson.safetyLevel, locale)}</dd>
            </div>
            <div>
              <dt>{copy.sources}</dt>
              <dd>{getSourceStatusLabel(lesson.sourceStatus, locale)}</dd>
            </div>
            <div>
              <dt>{copy.primaryTopic}</dt>
              <dd><code>{lesson.primaryTopicId}</code></dd>
            </div>
            <div>
              <dt>{copy.coveredTopics}</dt>
              <dd>{lesson.coveredTopicIds.length}</dd>
            </div>
            <div>
              <dt>{copy.id}</dt>
              <dd><code>{lesson.lessonId}</code></dd>
            </div>
          </dl>

          <div class="registry-badge-row" aria-label={copy.status}>
            <span class={`registry-badge registry-badge-safety-${lesson.safetyLevel}`}>
              {copy.safety}: {getSafetyLevelLabel(lesson.safetyLevel, locale)}
            </span>
            <span class={`registry-badge registry-badge-source-${lesson.sourceStatus}`}>
              {copy.sources}: {getSourceStatusLabel(lesson.sourceStatus, locale)}
            </span>
            <span class={lesson.requiresThailandContext ? "registry-badge registry-badge-thailand" : "registry-badge"}>
              {lesson.requiresThailandContext ? copy.thailandYes : copy.thailandNo}
            </span>
          </div>

          <div class="registry-card-footer">
            {hasPublicPage ? (
              <a class="text-link" href={lesson.paths[locale]}>{copy.publicPage}</a>
            ) : (
              <span>{copy.notPublic}</span>
            )}
          </div>
        </article>
      );
    })}
  </div>
</section>
