---
import SuggestionSection from "./SuggestionSection.astro";
import type { AtlasTopic } from "../lib/generated/atlasTopics";
import { getAvailableLessonForCoveredTopic, getLessonStatusLabel } from "../lib/lessonRegistry";
import { topicToSuggestion, type SuggestionItem } from "../lib/suggestions";
import { getTopicStatusLabel, getTopicTypeLabel } from "../lib/topicLabels";

interface Props {
  topic: AtlasTopic;
  locale?: "en" | "th";
  relatedTopics?: AtlasTopic[];
  relatedSuggestions?: SuggestionItem[];
}

const { topic, locale = "en", relatedTopics = [], relatedSuggestions: providedRelatedSuggestions } = Astro.props;

const copy = {
  en: {
    eyebrow: "topic record",
    recordStatusEyebrow: "record status",
    notLessonEyebrow: "record ≠ lesson",
    metadataEyebrow: "metadata",
    workflowEyebrow: "workflow",
    usageEyebrow: "usage",
    statusLabel: "Mapped, not a full lesson yet",
    canonicalNote:
      "Canonical topic names and summaries are currently English. Thai pages localize the interface; most mapped records do not yet have Thai topic copy.",
    primaryHome: "Primary home",
    whatThisIsTitle: "What this page is",
    whatThisIs:
      "This is a structured atlas record. It tells us where the topic belongs, how it should be classified, and what kind of future lesson or reference page it needs.",
    notLessonTitle: "What this page is not",
    notLesson:
      "This is not a complete explainer lesson yet. It does not replace researched lessons, visual diagrams, source review, translation, safety checks, or standards verification.",
    factsTitle: "Topic facts",
    canonicalId: "Canonical ID",
    type: "Node type",
    depth: "Expected depth",
    safety: "Safety tag",
    status: "Content status",
    domain: "Domain",
    section: "Section",
    subsection: "Subsection",
    sourceFile: "Inventory source",
    pipelineTitle: "Publishing pipeline",
    pipeline: [
      "Mapped in the atlas inventory",
      "Outlined as a lesson or reference page",
      "Researched from authoritative sources",
      "Illustrated with original visuals or interactive graphics",
      "Reviewed for technical accuracy and safety",
      "Localized into Thai/English publication copy",
      "Published as a finished lesson",
    ],
    useTitle: "How to use this record",
    useItems: [
      "Use it to confirm that a topic has a logical home in the atlas.",
      "Use its ID when asking to build a lesson next.",
      "Use the domain and section to understand what prerequisites may matter.",
      "Treat the summary as a map label, not as the final explanation.",
    ],
    map: "Back to knowledge map",
    guide: "How to use this site",
    firstLesson: "Read the first lesson",
    availableLesson: "Lesson available",
    openAvailableLesson: "Open lesson",
    mapped: "mapped",
    noSafetyTag: "No explicit safety tag yet",
  },
  th: {
    eyebrow: "บันทึกหัวข้อ",
    recordStatusEyebrow: "สถานะบันทึก",
    notLessonEyebrow: "บันทึก ≠ บทเรียน",
    metadataEyebrow: "ข้อมูลกำกับ",
    workflowEyebrow: "ขั้นตอนการทำงาน",
    usageEyebrow: "วิธีใช้งาน",
    statusLabel: "ทำแผนที่แล้ว แต่ยังไม่ใช่บทเรียนเต็ม",
    canonicalNote:
      "ขณะนี้ชื่อและสรุปมาตรฐานของหัวข้อส่วนใหญ่ยังเป็นภาษาอังกฤษ หน้าไทยแปลส่วนติดต่อแล้ว แต่หัวข้อที่ทำแผนที่ส่วนใหญ่ยังไม่มีชื่อและสรุปภาษาไทย",
    primaryHome: "บ้านหลักของหัวข้อ",
    whatThisIsTitle: "หน้านี้คืออะไร",
    whatThisIs:
      "นี่คือบันทึกหัวข้อแบบมีโครงสร้างของ atlas ใช้บอกว่าหัวข้อนี้ควรอยู่ตรงไหน ถูกจัดประเภทอย่างไร และในอนาคตควรพัฒนาเป็นบทเรียนหรือหน้าอ้างอิงแบบใด",
    notLessonTitle: "หน้านี้ยังไม่ใช่อะไร",
    notLesson:
      "หน้านี้ยังไม่ใช่บทเรียนอธิบายเต็มรูปแบบ ยังไม่แทนการค้นคว้า วาดภาพ ตรวจแหล่งอ้างอิง แปล ตรวจความปลอดภัย หรือยืนยันมาตรฐาน",
    factsTitle: "ข้อมูลหัวข้อ",
    canonicalId: "Canonical ID",
    type: "ชนิดของโหนด",
    depth: "ระดับความลึกที่คาดไว้",
    safety: "แท็กความปลอดภัย",
    status: "สถานะเนื้อหา",
    domain: "โดเมน",
    section: "หมวด",
    subsection: "หมวดย่อย",
    sourceFile: "ไฟล์ inventory",
    pipelineTitle: "ขั้นตอนก่อนเผยแพร่",
    pipeline: [
      "ทำแผนที่ไว้ใน inventory ของ atlas",
      "วาง outline เป็นบทเรียนหรือหน้าอ้างอิง",
      "ค้นคว้าจากแหล่งที่น่าเชื่อถือ",
      "วาดภาพหรือทำ interactive graphic ของเราเอง",
      "ตรวจความถูกต้องทางเทคนิคและความปลอดภัย",
      "ปรับเป็นภาษาไทย/อังกฤษสำหรับเผยแพร่",
      "เผยแพร่เป็นบทเรียนที่เสร็จสมบูรณ์",
    ],
    useTitle: "วิธีใช้บันทึกนี้",
    useItems: [
      "ใช้ยืนยันว่าหัวข้อนี้มีบ้านที่ชัดเจนใน atlas",
      "ใช้ ID นี้เมื่ออยากให้สร้างบทเรียนหัวข้อนี้ต่อ",
      "ใช้โดเมนและหมวดเพื่อดูว่าความรู้พื้นฐานใดอาจเกี่ยวข้อง",
      "ให้มองสรุปสั้นเป็นป้ายบนแผนที่ ไม่ใช่คำอธิบายสุดท้ายของบทเรียน",
    ],
    map: "กลับไปแผนที่ความรู้",
    guide: "วิธีใช้เว็บนี้",
    firstLesson: "อ่านบทเรียนแรก",
    availableLesson: "มีบทเรียนให้อ่าน",
    openAvailableLesson: "เปิดบทเรียน",
    mapped: "ทำแผนที่แล้ว",
    noSafetyTag: "ยังไม่มีแท็กความปลอดภัยเฉพาะ",
  },
}[locale];

const mapPath = locale === "th" ? "/th/map/" : "/en/map/";
const guidePath = locale === "th" ? "/th/guide/" : "/en/guide/";
const firstLessonPath = locale === "th" ? "/th/lessons/what-is-electricity/" : "/en/lessons/what-is-electricity/";
const availableLesson = getAvailableLessonForCoveredTopic(topic.id, locale);
const availableLessonPath = availableLesson?.paths[locale] || "";
const availableLessonMaturity = availableLesson ? getLessonStatusLabel(availableLesson.status, locale) : "";
const availableLessonLabel = availableLesson
  ? `${copy.availableLesson} · ${availableLessonMaturity}`
  : "";
const metadataRelatedSuggestions = relatedTopics.map((relatedTopic) =>
  topicToSuggestion(
    relatedTopic,
    locale,
    locale === "th"
      ? getTopicTypeLabel(relatedTopic.type, locale)
      : `${relatedTopic.type} · ${relatedTopic.section || relatedTopic.domain}`,
  ),
);
const relatedSuggestions = providedRelatedSuggestions ?? metadataRelatedSuggestions;
const relatedCopy = {
  en: {
    title: "Related topic records",
    intro: "These suggestions use explicit atlas relationships first, then nearby metadata such as subject, section, component family, or technical field.",
  },
  th: {
    title: "บันทึกหัวข้อที่เกี่ยวข้อง",
    intro: "ระบบเลือกจาก metadata ใกล้เคียงใน atlas เช่น วิชา หมวด กลุ่มชิ้นส่วน หรือสาขาเทคนิคที่คล้ายกัน",
  },
}[locale];
const relationAwareSuggestionIntro = {
  en: "These suggestions use explicit atlas relationships first, then nearby metadata such as subject, section, component family, or technical field.",
  th: "ระบบเลือกจากความสัมพันธ์ที่ระบุไว้ใน atlas ก่อน แล้วค่อยเติมด้วย metadata ใกล้เคียง เช่น วิชา หมวด กลุ่มชิ้นส่วน หรือสาขาเทคนิค",
}[locale];

const facts = [
  { label: copy.canonicalId, value: topic.id, code: true },
  { label: copy.type, value: getTopicTypeLabel(topic.type, locale) },
  { label: copy.depth, value: topic.depth },
  { label: copy.safety, value: topic.safety || copy.noSafetyTag },
  { label: copy.status, value: getTopicStatusLabel(topic.status, locale) },
  { label: copy.domain, value: topic.domain },
  { label: copy.section, value: topic.section },
  { label: copy.subsection, value: topic.subsection },
  { label: copy.sourceFile, value: topic.sourceFile, code: true },
].filter((fact) => fact.value);
---

<section class="topic-record-hero">
  <p class="eyebrow">{copy.eyebrow}</p>
  <h1>{topic.name}</h1>
  <p class="hero-subtitle">{topic.summary}</p>
  <div class="topic-record-pills" aria-label={copy.primaryHome}>
    <span>{getTopicTypeLabel(topic.type, locale)}</span>
    {topic.depth ? <span>{topic.depth}</span> : null}
    <span>{copy.statusLabel}</span>
  </div>
  <p class="topic-language-note">{copy.canonicalNote}</p>
  <div class="hero-actions">
    {availableLessonPath ? <a class="button" href={availableLessonPath}>{copy.openAvailableLesson}</a> : null}
    <a class="button" href={mapPath}>{copy.map}</a>
    <a class="button-secondary" href={guidePath}>{copy.guide}</a>
    <a class="button-secondary" href={firstLessonPath}>{copy.firstLesson}</a>
  </div>
</section>

<section class="topic-record-grid" aria-label={copy.factsTitle}>
  <article class="topic-record-panel">
    <p class="eyebrow">{copy.recordStatusEyebrow}</p>
    <h2>{copy.whatThisIsTitle}</h2>
    {availableLessonPath ? <p class="state-pill topic-lesson-available-pill">{availableLessonLabel}</p> : null}
    <p>{copy.whatThisIs}</p>
  </article>

  <article class="topic-record-panel warning-panel">
    <p class="eyebrow">{copy.notLessonEyebrow}</p>
    <h2>{copy.notLessonTitle}</h2>
    <p>{copy.notLesson}</p>
  </article>
</section>

<section class="topic-record-layout">
  <article class="topic-record-panel">
    <p class="eyebrow">{copy.metadataEyebrow}</p>
    <h2>{copy.factsTitle}</h2>
    <dl class="topic-fact-list">
      {facts.map((fact) => (
        <div>
          <dt>{fact.label}</dt>
          <dd>{fact.code ? <code>{fact.value}</code> : fact.value}</dd>
        </div>
      ))}
    </dl>
  </article>

  <div class="topic-record-stack">
    <article class="topic-record-panel">
      <p class="eyebrow">{copy.workflowEyebrow}</p>
      <h2>{copy.pipelineTitle}</h2>
      <ol class="topic-pipeline-list">
        {copy.pipeline.map((step) => <li>{step}</li>)}
      </ol>
    </article>

    <article class="topic-record-panel">
      <p class="eyebrow">{copy.usageEyebrow}</p>
      <h2>{copy.useTitle}</h2>
      <ul class="topic-usage-list">
        {copy.useItems.map((item) => <li>{item}</li>)}
      </ul>
    </article>
  </div>
</section>

<SuggestionSection
  locale={locale}
  items={relatedSuggestions}
  title={relatedCopy.title}
  intro={relationAwareSuggestionIntro}
/>
