---
import TopicRecord from "../../../components/TopicRecord.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { atlasTopics } from "../../../lib/generated/atlasTopics";
import type { AtlasTopic } from "../../../lib/generated/atlasTopics";
import { getRelatedTopicSuggestions, type SuggestionItem } from "../../../lib/suggestions";

interface Props {
  topic: AtlasTopic;
  relatedSuggestions: SuggestionItem[];
}

export function getStaticPaths() {
  return atlasTopics.map((topic) => ({
    params: { slug: topic.slug },
    props: { topic, relatedSuggestions: getRelatedTopicSuggestions(topic, atlasTopics, "th") },
  }));
}

const { topic, relatedSuggestions } = Astro.props;
---

<BaseLayout
  title={`${topic.name} — บันทึกหัวข้อ`}
  description={`บันทึกหัวข้อ Electrical Atlas สำหรับ ${topic.name}: ${topic.summary}`}
  lang="th"
  noindex
  counterpartPath={`/en/topics/${topic.slug}/`}
>
  <TopicRecord topic={topic} relatedSuggestions={relatedSuggestions} locale="th" />
</BaseLayout>
