---
import TopicRecord from "../../../components/TopicRecord.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { atlasTopics } from "../../../lib/generated/atlasTopics";
import type { AtlasTopic } from "../../../lib/generated/atlasTopics";
import { getRelatedTopics } from "../../../lib/suggestions";

interface Props {
  topic: AtlasTopic;
  relatedTopics: AtlasTopic[];
}

export function getStaticPaths() {
  return atlasTopics.map((topic) => ({
    params: { slug: topic.slug },
    props: { topic, relatedTopics: getRelatedTopics(topic, atlasTopics) },
  }));
}

const { topic, relatedTopics } = Astro.props;
---

<BaseLayout
  title={`${topic.name} — บันทึกหัวข้อ`}
  description={`บันทึกหัวข้อ Electrical Atlas สำหรับ ${topic.name}: ${topic.summary}`}
  lang="th"
  counterpartPath={`/en/topics/${topic.slug}/`}
  counterpartLabel="English"
>
  <TopicRecord topic={topic} relatedTopics={relatedTopics} locale="th" />
</BaseLayout>
