---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LessonShell from "../../../components/LessonShell.astro";
import LessonModeToggle from "../../../components/LessonModeToggle";
import PowerEnergyDemo from "../../../components/PowerEnergyDemo";
import SuggestionSection from "../../../components/SuggestionSection.astro";
import Content from "../../../content/lessons/th/power-energy.mdx";
import { atlasTopics } from "../../../lib/generated/atlasTopics";
import { getLessonSuggestions } from "../../../lib/suggestions";

const suggestions = getLessonSuggestions("power-energy", "th", atlasTopics);
---

<BaseLayout
  title="กำลังและพลังงานไฟฟ้า"
  description="บทเรียนภาพอธิบายกำลังไฟฟ้า พลังงาน วัตต์ จูล วัตต์-ชั่วโมง ความร้อน แบตเตอรี่ และข้อจำกัดด้านความปลอดภัย"
  lang="th"
  counterpartPath="/en/lessons/power-energy/"
>
  <LessonShell
    locale="th"
    eyebrow="บทเรียนพื้นฐาน"
    title="กำลังและพลังงานไฟฟ้า"
    subtitle="กำลังคืออัตราการถ่ายเทพลังงานไฟฟ้า ส่วนพลังงานคือปริมาณที่สะสมตามเวลา"
    lessonId="ea.lesson.power-energy.v0.1"
  >
    <LessonModeToggle client:load locale="th" />
    <PowerEnergyDemo client:load locale="th" />
    <div class="lesson-content">
      <Content />
    </div>
    <SuggestionSection locale="th" items={suggestions} />
  </LessonShell>
</BaseLayout>
