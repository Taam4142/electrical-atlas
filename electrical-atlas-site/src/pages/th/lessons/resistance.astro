---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LessonShell from "../../../components/LessonShell.astro";
import LessonModeToggle from "../../../components/LessonModeToggle";
import ResistanceConductanceDemo from "../../../components/ResistanceConductanceDemo";
import SuggestionSection from "../../../components/SuggestionSection.astro";
import Content from "../../../content/lessons/th/resistance.mdx";
import { atlasTopics } from "../../../lib/generated/atlasTopics";
import { getLessonSuggestions } from "../../../lib/suggestions";

const suggestions = getLessonSuggestions("resistance", "th", atlasTopics);
---

<BaseLayout
  title="ความต้านทานและความนำไฟฟ้า"
  description="บทเรียนพื้นฐานอธิบายความต้านทาน ความนำไฟฟ้า ภาพจำของกฎโอห์ม การจำกัดกระแส และความร้อน"
  lang="th"
  counterpartPath="/en/lessons/resistance/"
>
  <LessonShell
    locale="th"
    eyebrow="บทเรียนพื้นฐาน"
    title="ความต้านทานและความนำไฟฟ้า"
    subtitle="ความต้านทานบอกว่าเส้นทางขัดขวางกระแสมากแค่ไหน ส่วนความนำไฟฟ้าบอกว่าเส้นทางยอมให้กระแสผ่านง่ายแค่ไหน"
    lessonId="ea.lesson.resistance.v0.1"
  >
    <LessonModeToggle client:load locale="th" />
    <ResistanceConductanceDemo client:load locale="th" />
    <div class="lesson-content">
      <Content />
    </div>
    <SuggestionSection locale="th" items={suggestions} />
  </LessonShell>
</BaseLayout>
