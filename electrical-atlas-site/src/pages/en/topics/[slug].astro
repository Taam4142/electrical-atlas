---
import TopicRecord from "../../../components/TopicRecord.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { atlasTopics } from "../../../lib/generated/atlasTopics";
import type { AtlasTopic } from "../../../lib/generated/atlasTopics";
import { getRelatedTopicSuggestions, type SuggestionItem } from "../../../lib/suggestions";

interface Props {
  topic: AtlasTopic;
  relatedSuggestions: SuggestionItem[];
}

export function getStaticPaths() {
  return atlasTopics.map((topic) => ({
    params: { slug: topic.slug },
    props: { topic, relatedSuggestions: getRelatedTopicSuggestions(topic, atlasTopics, "en") },
  }));
}

const { topic, relatedSuggestions } = Astro.props;
---

<BaseLayout
  title={`${topic.name} Topic Record`}
  description={`Mapped Electrical Atlas topic record for ${topic.name}: ${topic.summary}`}
  lang="en"
  noindex
  counterpartPath={`/th/topics/${topic.slug}/`}
  counterpartLabel="ไทย"
>
  <TopicRecord topic={topic} relatedSuggestions={relatedSuggestions} locale="en" />
</BaseLayout>
