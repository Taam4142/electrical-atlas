---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroCircuit from "../components/HeroCircuit.astro";
---

<BaseLayout
  title="Electrical Atlas"
  description="A bilingual visual website prototype for learning electricity and electronics from first principles."
  lang="en"
  counterpartPath="/th/"
>
  <section class="hero">
    <div>
      <p class="eyebrow">prototype v0.1</p>
      <h1>Electrical Atlas</h1>
      <p class="hero-subtitle">
        A visual, bilingual knowledge map for electricity and electronics — starting with the deceptively simple
        question: what is electricity?
      </p>
    </div>
    <HeroCircuit locale="en" />
  </section>

  <section class="choice-grid" aria-label="Choose your language">
    <a class="choice-card" href="/en/" lang="en">
      <p class="eyebrow">English</p>
      <h2>Open the English atlas</h2>
      <p>Start with the guide, browse available lessons, or explore the complete subject map.</p>
    </a>
    <a class="choice-card" href="/th/" lang="th">
      <p class="eyebrow">ภาษาไทย</p>
      <h2>เปิดแผนที่ความรู้ภาษาไทย</h2>
      <p>เริ่มจากคู่มือ เลือกบทเรียนที่เปิดอ่านได้ หรือสำรวจแผนที่วิชาทั้งหมด</p>
    </a>
  </section>
</BaseLayout>
